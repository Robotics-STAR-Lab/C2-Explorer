<launch>
    <arg name="drone_id" default="1"/>
    <arg name="drone_num" default="1"/> 
    <arg name="broadcast_ip" default="127.0.0.255"/>

    <arg name="lidar_pitch" default="0.0"/>

    <arg name="color_r" default="0.0"/>
    <arg name="color_g" default="1.0"/>
    <arg name="color_b" default="1.0"/>

    <arg name="simulation" default="true"/>

    <arg name="odom_prefix" default="odom"/>

    <arg name="sensor_pose_topic"/> 
    <arg name="depth_topic"/> 
    <arg name="cloud_topic"/>

    <arg name="max_vel"/>
    <arg name="max_acc"/>

    <arg name="map_model" default="forest_50x50_01_200"/>

  <!-- main algorithm params -->

  <include file="$(find exploration_manager)/launch/real_outdoor_planner.xml">
    <arg name="drone_id" value="$(arg drone_id)"/>
    <arg name="drone_num" value="$(arg drone_num)"/>


    <arg name="max_vel" value="$(arg max_vel)" /> 
    <arg name="max_acc" value="$(arg max_acc)" />

    <arg name="odometry_topic" value="$(arg odom_prefix)"/>
    <arg name="sensor_pose_topic" value="$(arg sensor_pose_topic)"/>
    <arg name="depth_topic" value="$(arg depth_topic)"/>
    <arg name="cloud_topic" value="$(arg cloud_topic)"/>

    <arg name="lidar_pitch" value="$(arg lidar_pitch)"/>
    <arg name="simulation" value="$(arg simulation)"/>

    <arg name="map_model" value="$(arg map_model)"/>

    <arg name="color_r" value="$(arg color_r)"/>
    <arg name="color_g" value="$(arg color_g)"/>
    <arg name="color_b" value="$(arg color_b)"/>
  </include>


  <!-- trajectory server -->
  <node pkg="plan_manage" name="traj_server_$(arg drone_id)" type="traj_server" output="screen">
    <!-- simulation mode -->
    <remap from="/odom_world" to="$(arg odom_prefix)_$(arg drone_id)" if="$(arg simulation)"/>
    <remap from="/position_cmd" to="planning/pos_cmd_$(arg drone_id)" if="$(arg simulation)"/>
    
    <!-- real mode: px4ctrl -->
    <remap from="/odom_world" to="$(arg odom_prefix)" unless="$(arg simulation)"/>
    <remap from="/position_cmd" to="/fsm/pos_cmd" unless="$(arg simulation)"/>
    
    <remap from="planning/bspline" to="/planning/bspline_$(arg drone_id)" />
    <remap from="planning/replan" to="/planning/replan_$(arg drone_id)" />
    <remap from="planning/new" to="/planning/new_$(arg drone_id)" />
    
    <remap from="planning/position_cmd_vis" to="planning/position_cmd_vis_$(arg drone_id)" />
    <remap from="planning/travel_traj" to="planning/travel_traj_$(arg drone_id)" />
    <remap from="planning/travel_traj_vel" to="planning/travel_traj_vel_$(arg drone_id)" />

    <param name="traj_server/time_forward" value="1.5" type="double"/>
    <param name="traj_server/pub_traj_id" value="4" type="int"/>
    <param name="traj_server/pub_traj_vel_id" value="4" type="int"/>
    <param name="traj_server/drone_id" value="$(arg drone_id)" type="int"/>
    <param name="traj_server/drone_num" value="$(arg drone_num)" type="int"/>
    <param name="traj_server/max_vel" value="2.0" type="double"/>
    
    <param name="perception_utils/lidar_pitch" value="$(arg lidar_pitch)" />
    <param name="perception_utils/lidar_top_angle" value="$(eval 38 * 3.1415926 / 180.0)" type="double"/>
    <param name="perception_utils/lidar_bottom_angle" value="$(eval 8 * 3.1415926 / 180.0)" type="double"/>
    <param name="perception_utils/lidar_left_angle" value="$(eval 60 * 3.1415926 / 180.0)" type="double"/>
    <param name="perception_utils/lidar_right_angle" value="$(eval 60 * 3.1415926 / 180.0)" type="double"/>
    <param name="perception_utils/lidar_max_dist" value="22.0" type="double"/>
    <param name="perception_utils/lidar_vis_dist" value="1.0" type="double"/>
    
    <param name="color_r" value="$(arg color_r)"/>
    <param name="color_g" value="$(arg color_g)"/>
    <param name="color_b" value="$(arg color_b)"/>
    <param name="color_a" value="1.0"/>
  </node>

  <!-- swarm bridge for multi-drone communication -->
  <include file="$(find swarm_bridge)/launch/bridge_udp.launch">
    <arg name="drone_id" value="$(arg drone_id)"/>
    <arg name="broadcast_ip" value="$(arg broadcast_ip)"/>
  </include>

</launch>
